# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_REASONING=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_TEMPERATURE=0

# Database Configuration
DATABASE_URI=sqlite:///./data/database.db
# For CSV/Excel files: Use setup_db.py to create database
# python setup_db.py --source ./data/your_file.csv
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
# For Snowflake: snowflake://user:password@account/database/schema

# Vector Store Configuration (ChromaDB)
VECTOR_STORE_PATH=./data/vector_store
CHROMA_COLLECTION_NAME=sql_examples

# Embedding Model (HuggingFace - runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Caching Configuration (Disk Cache)
ENABLE_SEMANTIC_CACHE=true
CACHE_SIMILARITY_THRESHOLD=0.95

# Agent Configuration
MAX_ITERATIONS=3
ENABLE_SELF_CORRECTION=true
ENABLE_DYNAMIC_FEW_SHOT=true
FEW_SHOT_EXAMPLES_COUNT=3

# Performance Configuration
QUERY_TIMEOUT_SECONDS=30
